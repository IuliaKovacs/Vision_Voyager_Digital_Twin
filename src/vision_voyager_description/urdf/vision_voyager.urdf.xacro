<?xml version="1.0"?>
<robot name="vision_voyager" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="chassis_mass" value="0.8"/>
  <xacro:property name="wheel_mass" value="0.1"/>
  <xacro:property name="wheel_radius" value="0.032"/>
  <xacro:property name="wheel_width" value="0.015"/>
  <xacro:property name="wheelbase" value="0.12"/>
  <xacro:property name="track_width" value="0.1"/>

  <material name="blue"><color rgba="0.1 0.4 0.8 1"/></material>
  <material name="black"><color rgba="0.05 0.05 0.05 1"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="chassis"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="chassis">
    <visual>
      <geometry><box size="0.16 0.09 0.01"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="0.16 0.09 0.01"/></geometry>
    </collision>
    <inertial>
      <mass value="${chassis_mass}"/>
      <inertia ixx="0.00054" ixy="0" ixz="0" iyy="0.00171" iyz="0" izz="0.00224"/>
    </inertial>
  </link>

  <link name="ultrasonic_link">
    <visual>
      <geometry><box size="0.02 0.05 0.02"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><box size="0.02 0.05 0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="ultrasonic_joint" type="fixed">
    <parent link="chassis"/>
    <child link="ultrasonic_link"/>
    <origin xyz="0.08 0 0.03" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="rear_wheel" params="prefix y_reflect">
    <link name="rear_${prefix}_wheel">
      <visual>
        <origin rpy="${pi/2} 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00005"/>
      </inertial>
    </link>
    <joint name="rear_${prefix}_wheel_joint" type="continuous">
      <parent link="chassis"/>
      <child link="rear_${prefix}_wheel"/>
      <origin xyz="-${wheelbase/2} ${y_reflect * track_width/2} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="front_wheel" params="prefix y_reflect">
    <link name="front_${prefix}_steer_link">
      <inertial><mass value="0.01"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial>
    </link>
    <joint name="front_${prefix}_steer_joint" type="revolute">
      <parent link="chassis"/>
      <child link="front_${prefix}_steer_link"/>
      <origin xyz="${wheelbase/2} ${y_reflect * track_width/2} 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.52" upper="0.52" effort="5.0" velocity="1.0"/>
    </joint>
    <link name="front_${prefix}_wheel">
      <visual>
        <origin rpy="${pi/2} 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00005"/>
      </inertial>
    </link>
    <joint name="front_${prefix}_wheel_joint" type="continuous">
      <parent link="front_${prefix}_steer_link"/>
      <child link="front_${prefix}_wheel"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:rear_wheel prefix="left" y_reflect="1"/>
  <xacro:rear_wheel prefix="right" y_reflect="-1"/>
  <xacro:front_wheel prefix="left" y_reflect="1"/>
  <xacro:front_wheel prefix="right" y_reflect="-1"/>

  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <left_steering_joint>front_left_steer_joint</left_steering_joint>
      <right_steering_joint>front_right_steer_joint</right_steering_joint>
      <wheel_separation>${track_width}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>cmd_vel</topic>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>
    
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

  <gazebo reference="ultrasonic_link">
    <sensor name="hc_sr04" type="gpu_lidar">
      <gz_frame_id>ultrasonic_link</gz_frame_id>
      <topic>/ultrasonic/scan</topic>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>3</samples>
            <resolution>1</resolution>
            <min_angle>-0.15</min_angle>
            <max_angle>0.15</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>3.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>

</robot>